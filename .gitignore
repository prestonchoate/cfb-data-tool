# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
MANIFEST

# PyInstaller (generated manifests/specs — but keep our hand-written spec)
*.manifest
*.spec
!packaging/*.spec

# Generated platform icons (rebuilt by packaging/gen_icons.py)
packaging/icon.icns
packaging/icon.ico

# Virtual environments
.venv/
venv/

# Unit test / coverage reports
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pytype/

# --- cfb-data-tool ---
# Local test screenshots (large; full corpus lives outside the repo, see tests/)
tests/fixtures/screenshots/
tests/reports/
# Scraped output / local DB
*.db
recruits_scraped.csv
